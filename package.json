{
  "name": "fintrack-pro",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "start": "node server/index.js",
    "server": "node server/index.js",
    "client": "vite --host 0.0.0.0 --config client/vite.config.js",
    "build": "vite build --config client/vite.config.js",
    "preview": "vite preview --host 0.0.0.0 --config client/vite.config.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "lucide-react": "^0.468.0",
    "multer": "^2.0.2",
    "recharts": "^2.12.2",
    "vite": "^5.1.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.18",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1"
  }
}
